<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.corelearning.mapper.UserMapper">
    <select id="userAll" resultType="Integer">
        select * from user
    </select>
    <select id="selectByCondition" resultType="com.example.corelearning.dto.UserDto">
        select * from user
        <where>
            <if test="username != null and username != ''">
                and username like concat('%', #{username}, '%')
            </if>
            <if test="age !=null">
                and age = #{age}
            </if>
        </where>
    </select>
</mapper>
